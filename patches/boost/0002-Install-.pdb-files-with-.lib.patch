From 0eea93ae2270171a5414847ffd754bc8b549f7dd Mon Sep 17 00:00:00 2001
From: O01eg <o01eg@yandex.ru>
Date: Sat, 4 Apr 2026 10:50:37 +0400
Subject: [PATCH 1/3] Install .pdb files with .lib

---
 tools/cmake/include/BoostInstall.cmake | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/tools/cmake/include/BoostInstall.cmake b/tools/cmake/include/BoostInstall.cmake
index 1127c6f3..2e61366b 100644
--- a/tools/cmake/include/BoostInstall.cmake
+++ b/tools/cmake/include/BoostInstall.cmake
@@ -310,7 +310,7 @@ function(boost_install_target)
 
   if(MSVC)
     if(TYPE STREQUAL "SHARED_LIBRARY")
-      install(FILES $<TARGET_PDB_FILE:${LIB}> DESTINATION ${CMAKE_INSTALL_BINDIR} OPTIONAL)
+      install(FILES $<TARGET_PDB_FILE:${LIB}> DESTINATION ${CMAKE_INSTALL_LIBDIR} OPTIONAL)
     endif()
 
     if(TYPE STREQUAL "STATIC_LIBRARY" AND NOT CMAKE_VERSION VERSION_LESS 3.15)
